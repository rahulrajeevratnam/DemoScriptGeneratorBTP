# Local development only — on Cloud Foundry these are provided automatically
# via bound service instances (VCAP_SERVICES) defined in mta.yaml.

PORT=3000

# --- SAP AI Core (Generative AI Hub) ---
# On CF: bound automatically from the "aicore" service instance (see mta.yaml).
# Locally: paste the full AI Core service key JSON on one line.
# AICORE_SERVICE_KEY={"clientid":"...","clientsecret":"...","url":"...","serviceurls":{"AI_API_URL":"..."}}

# Model deployed in your AI Core Generative AI Hub configuration/orchestration
# deployment. Verify the exact name in your AI Core model catalog.
AICORE_ORCHESTRATION_MODEL=anthropic--claude-4.6-sonnet
AICORE_MAX_TOKENS=8192

# Experimental /api/generate-gemini pipeline (public/gemini.html) — sends the
# video directly to Gemini for native video understanding, for comparison
# against the standard Claude pipeline above. Does not affect it.
AICORE_GEMINI_MODEL=gemini-2.5-flash
AICORE_GEMINI_MAX_TOKENS=32768

# --- SAP Object Store (S3-compatible) ---
# On CF: bound automatically from the "objectstore" service instance (see mta.yaml).
# Locally: point at a real S3-compatible bucket (AWS S3, MinIO, etc.).
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key
S3_HOST=s3.amazonaws.com
S3_REGION=us-east-1
